{
  "manifest_version": 3,
  "name": "Hindi Helper",
  "version": "0.1.0",
  "description": "Select a word for Hindi meaning, or text for Hindi summary.",
  "permissions": ["storage"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["content.js"],
    "css": ["content.css"],
    "run_at": "document_idle"
  }],
  "options_ui": { "page": "options.html", "open_in_tab": true }
}
